diff --git a/shared/config/qemu/init.vendor.qemu.rc b/shared/config/qemu/init.vendor.qemu.rc
new file mode 100644
index 0000000..e7a9644
--- /dev/null
+++ b/shared/config/qemu/init.vendor.qemu.rc
@@ -0,0 +1,14 @@
+# QEMU-specific init deltas layered on top of init.cutf_cvm.rc.
+#
+# This file intentionally avoids replacing the stock cuttlefish init module,
+# which causes an install-path conflict during the build. The goal here is to
+# keep the build graph valid while applying a few runtime adjustments that are
+# harmless if the corresponding services are absent.
+
+on post-fs-data
+    stop setup_wifi
+    stop init_wifi_sh
+    exec -- /system/bin/ip link set eth0 up
+
+on boot
+    stop socket_vsock_proxy
diff --git a/vsoc_arm64_only/phone/aosp_cf_qemu.mk b/vsoc_arm64_only/phone/aosp_cf_qemu.mk
new file mode 100644
index 0000000..6232ec2
--- /dev/null
+++ b/vsoc_arm64_only/phone/aosp_cf_qemu.mk
@@ -0,0 +1,56 @@
+#
+# Copyright (C) 2024 The Android Open Source Project
+#
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#      http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+#
+
+# QEMU flavor: inherits stock arm64-only phone and adds a small set of QEMU-
+# specific deltas that do not require replacing inherited product lists.
+
+# Keep the direct QEMU image on purely in-guest security HALs.
+TRUSTY_SYSTEM_VM := disabled
+LOCAL_GATEKEEPER_PRODUCT_PACKAGES := com.android.hardware.gatekeeper.nonsecure
+LOCAL_KEYMINT_PRODUCT_PACKAGES := com.android.hardware.keymint.rust_nonsecure
+LOCAL_GRAPHICS_COMPOSER_PRODUCT_PACKAGES := com.android.hardware.graphics.composer.ranchu
+
+$(call inherit-product, device/google/cuttlefish/vsoc_arm64_only/phone/aosp_cf.mk)
+
+PRODUCT_NAME := aosp_cf_arm64_only_phone_qemu
+PRODUCT_MODEL := Cuttlefish arm64 phone 64-bit only (QEMU)
+
+# ---------------------------------------------------------------------------
+# ADB over TCP (no vsock transport)
+# ---------------------------------------------------------------------------
+PRODUCT_VENDOR_PROPERTIES += \
+    persist.adb.tcp.port=5555 \
+    ro.vendor.disable_rename_eth0=1
+
+# ---------------------------------------------------------------------------
+# QEMU-specific metadata
+# ---------------------------------------------------------------------------
+PRODUCT_VENDOR_PROPERTIES += \
+    ro.cuttlefish.guest_profile=cuttlefish-qemu \
+    ro.cuttlefish.adb_transport=rawTcp \
+    ro.cuttlefish.guest_adb_port=5555
+
+# ---------------------------------------------------------------------------
+# Graphics: keep both gfxstream and virgl/Mesa, default to virgl
+# ---------------------------------------------------------------------------
+PRODUCT_VENDOR_PROPERTIES += \
+    ro.hardware.egl=mesa
+
+# ---------------------------------------------------------------------------
+# Additional QEMU init adjustments layered on top of stock cuttlefish init
+# ---------------------------------------------------------------------------
+PRODUCT_PACKAGES += \
+    device_google_cuttlefish_qemu_config_init_vendor_rc

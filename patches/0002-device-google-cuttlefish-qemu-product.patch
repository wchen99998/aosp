diff --git a/vsoc_arm64_only/phone/aosp_cf_qemu.mk b/vsoc_arm64_only/phone/aosp_cf_qemu.mk
new file mode 100644
index 0000000..f77ef82
--- /dev/null
+++ b/vsoc_arm64_only/phone/aosp_cf_qemu.mk
@@ -0,0 +1,126 @@
+#
+# Copyright (C) 2024 The Android Open Source Project
+#
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#      http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+#
+
+# QEMU flavor: inherits stock arm64-only phone and adds a small set of QEMU-
+# specific deltas that do not require replacing inherited product lists.
+
+# Keep the direct QEMU image on purely in-guest security HALs.
+TRUSTY_SYSTEM_VM := disabled
+LOCAL_GATEKEEPER_PRODUCT_PACKAGES := com.android.hardware.gatekeeper.nonsecure
+LOCAL_KEYMINT_PRODUCT_PACKAGES := com.android.hardware.keymint.rust_nonsecure
+# Ship both composer backends and let boot-time selection pick the active one.
+# Ship both gralloc backends as standalone vendor binaries (no APEX).
+# The minigbm init_rc starts by default; init.vendor.qemu.rc switches to
+# ranchu when QEMU_BOOT_HARDWARE_GRALLOC=ranchu.
+LOCAL_GRALLOC_PRODUCT_PACKAGES := \
+    android.hardware.graphics.allocator-service.minigbm \
+    mapper.minigbm \
+    android.hardware.graphics.allocator-service.ranchu
+LOCAL_ENABLE_GAME_DEFAULT_FRAME_RATE_OVERRIDE := false
+LOCAL_SYSTEM_GAME_DEFAULT_FRAME_RATE_OVERRIDE := 0
+BOARD_HAVE_BLUETOOTH := false
+LOCAL_ENABLE_LIGHT := false
+LOCAL_ENABLE_NFC := false
+LOCAL_ENABLE_THREADNETWORK := false
+LOCAL_ENABLE_UWB := false
+LOCAL_USE_VENDOR_AUDIO_CONFIGURATION := true
+$(call soong_config_set_bool,bootclasspath,disable_bluetooth_mainline_module,true)
+$(call soong_config_set_bool,bootclasspath,disable_uwb_mainline_module,true)
+
+BOARD_VENDOR_SEPOLICY_DIRS += device/google/cuttlefish/shared/config/qemu/sepolicy
+
+$(call inherit-product, device/google/cuttlefish/vsoc_arm64_only/phone/aosp_cf.mk)
+
+PRODUCT_NAME := aosp_cf_arm64_only_phone_qemu
+PRODUCT_MODEL := Cuttlefish arm64 phone 64-bit only (QEMU)
+
+# ---------------------------------------------------------------------------
+# ADB over TCP (no vsock transport)
+# ---------------------------------------------------------------------------
+PRODUCT_VENDOR_PROPERTIES += \
+    persist.adb.tcp.port=5555 \
+    ro.vendor.disable_rename_eth0=1
+
+# ---------------------------------------------------------------------------
+# QEMU-specific metadata
+# ---------------------------------------------------------------------------
+PRODUCT_VENDOR_PROPERTIES += \
+    ro.cuttlefish.guest_profile=cuttlefish-qemu \
+    ro.cuttlefish.adb_transport=rawTcp \
+    ro.cuttlefish.guest_adb_port=5555
+
+# Disable the game-default-frame-rate path for QEMU validation products.
+# On this branch the runtime GameManager path is governed by
+# debug.graphics.game_default_frame_rate.disabled, while the read-only
+# ro.surface_flinger.game_default_frame_rate_override still seeds the default
+# override value.
+PRODUCT_PRODUCT_PROPERTIES += \
+    persist.graphics.game_default_frame_rate.enabled=false
+
+PRODUCT_SYSTEM_PROPERTIES += \
+    debug.graphics.game_default_frame_rate.disabled=true
+
+# QEMU needs one extra framebuffer acquire slot to keep SurfaceFlinger from
+# stalling on the guest display path.
+PRODUCT_DEFAULT_PROPERTY_OVERRIDES += \
+    ro.surface_flinger.max_frame_buffer_acquired_buffers=3
+
+# Core framework services still resolve Bluetooth and NFC API classes during
+# boot even when the runtime stacks are removed. Keep the API jars on the
+# platform bootclasspath for QEMU while leaving the Bluetooth mainline/service
+# stack disabled and the NFC stack absent from the image.
+PRODUCT_BOOT_JARS += \
+    framework-bluetooth \
+    framework-nfc
+
+# Keep the qemu product audio policy aligned with the removed Bluetooth stack.
+PRODUCT_PACKAGES += \
+    framework-bluetooth \
+    framework-nfc \
+    com.google.cf.qemu.hardware.audio \
+    device_google_cuttlefish_qemu_config_audio_policy
+
+PRODUCT_ARTIFACT_PATH_REQUIREMENT_ALLOWED_LIST += \
+    $(TARGET_COPY_OUT_SYSTEM)/framework/framework-bluetooth.jar \
+    $(TARGET_COPY_OUT_SYSTEM)/framework/framework-nfc.jar \
+    $(TARGET_COPY_OUT_SYSTEM)/framework/oat/arm64/framework-bluetooth.odex \
+    $(TARGET_COPY_OUT_SYSTEM)/framework/oat/arm64/framework-bluetooth.vdex \
+    $(TARGET_COPY_OUT_SYSTEM)/framework/oat/arm64/framework-nfc.odex \
+    $(TARGET_COPY_OUT_SYSTEM)/framework/oat/arm64/framework-nfc.vdex
+
+PRODUCT_COPY_FILES += \
+    frameworks/av/media/libeffects/data/audio_effects.xml:$(TARGET_COPY_OUT_VENDOR)/etc/audio_effects.xml \
+    frameworks/av/services/audiopolicy/config/audio_policy_volumes.xml:$(TARGET_COPY_OUT_VENDOR)/etc/audio_policy_volumes.xml \
+    frameworks/av/services/audiopolicy/config/default_volume_tables.xml:$(TARGET_COPY_OUT_VENDOR)/etc/default_volume_tables.xml \
+    frameworks/av/services/audiopolicy/config/r_submix_audio_policy_configuration.xml:$(TARGET_COPY_OUT_VENDOR)/etc/r_submix_audio_policy_configuration.xml \
+    frameworks/av/services/audiopolicy/config/surround_sound_configuration_5_0.xml:$(TARGET_COPY_OUT_VENDOR)/etc/surround_sound_configuration_5_0.xml \
+    frameworks/av/services/audiopolicy/config/usb_audio_policy_configuration.xml:$(TARGET_COPY_OUT_VENDOR)/etc/usb_audio_policy_configuration.xml \
+    hardware/interfaces/audio/aidl/default/audio_effects_config.xml:$(TARGET_COPY_OUT_VENDOR)/etc/audio_effects_config.xml \
+    device/google/cuttlefish/shared/uwb/excluded_hardware.xml:$(TARGET_COPY_OUT_VENDOR)/etc/permissions/uwb_excluded_hardware.xml
+
+# ---------------------------------------------------------------------------
+# Graphics: do not bake in a read-only backend choice here. The actual guest
+# graphics backend is selected at launch time via androidboot.hardware.* so the
+# same image can be used with software rendering, virgl, or gfxstream-capable
+# hosts.
+# ---------------------------------------------------------------------------
+# ---------------------------------------------------------------------------
+# Additional QEMU init adjustments layered on top of stock cuttlefish init
+# ---------------------------------------------------------------------------
+PRODUCT_PACKAGES += \
+    cuttlefish_qemu_overlay_frameworks_base_core \
+    device_google_cuttlefish_qemu_config_init_vendor_rc \
+    device_google_cuttlefish_qemu_config_mapper_ranchu_manifest
